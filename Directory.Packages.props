<Project>
  <PropertyGroup>
    <ManagePackageVersionsCentrally>true</ManagePackageVersionsCentrally>
  </PropertyGroup>
  <ItemGroup>
    <!-- Umbraco -->
    <PackageVersion Include="Umbraco.Cms" Version="17.0.2" />
    <PackageVersion Include="Umbraco.Cms.Core" Version="17.0.2" />
    <PackageVersion Include="Umbraco.Cms.Infrastructure" Version="17.0.2" />
    <PackageVersion Include="Umbraco.Cms.Web.Common" Version="17.0.2" />
    <PackageVersion Include="Umbraco.Cms.Web.Website" Version="17.0.2" />
    <PackageVersion Include="Umbraco.Cms.Api.Common" Version="17.0.2" />
    <PackageVersion Include="Umbraco.Cms.Api.Management" Version="17.0.2" />
    <!-- Umbraco Cloud & Deploy -->
    <PackageVersion Include="Umbraco.Cloud.Cms" Version="17.0.0" />
    <PackageVersion Include="Umbraco.Cloud.StorageProviders.AzureBlob" Version="17.0.0" />
    <PackageVersion Include="Umbraco.Deploy.OnPrem" Version="17.0.0" />
    <PackageVersion Include="Umbraco.Deploy.Cloud" Version="17.0.0" />
    <!-- Umbraco Forms -->
    <PackageVersion Include="Umbraco.Forms" Version="17.0.2" />
    <PackageVersion Include="Umbraco.Forms.Deploy" Version="17.0.0" />
    <!-- Umbraco Community Packages -->
    <PackageVersion Include="Umbraco.Community.BlockPreview" Version="5.0.0" />
    <PackageVersion Include="Umbraco.Community.Contentment" Version="6.0.2" />
    <!-- Hangfire -->
    <PackageVersion Include="Cultiv.Hangfire" Version="5.2.0" />
    <!-- Microsoft -->
    <PackageVersion Include="Microsoft.EntityFrameworkCore.Design" Version="10.0.0" />
    <PackageVersion Include="Microsoft.EntityFrameworkCore.Sqlite" Version="10.0.0" />
    <PackageVersion Include="Microsoft.EntityFrameworkCore.SqlServer" Version="10.0.0" />
    <PackageVersion Include="Microsoft.ICU.ICU4C.Runtime" Version="72.1.0.3" />
    <!-- Other -->
    <PackageVersion Include="Joonasw.AspNetCore.SecurityHeaders" Version="6.0.0" />
    <PackageVersion Include="Markdig" Version="0.44.0" />
    <PackageVersion Include="Schema.NET" Version="13.0.0" />
    <!-- Testing -->
    <PackageVersion Include="coverlet.collector" Version="6.0.4" />
    <PackageVersion Include="Microsoft.NET.Test.Sdk" Version="18.0.0" />
    <PackageVersion Include="xunit" Version="2.9.3" />
    <PackageVersion Include="xunit.runner.visualstudio" Version="3.1.4" />
    <PackageVersion Include="Moq" Version="4.20.72" />
    <PackageVersion Include="FluentAssertions" Version="7.0.0" />
    <!-- NUnit Testing (for Umbraco integration tests) -->
    <PackageVersion Include="NUnit" Version="3.14.0" />
    <PackageVersion Include="NUnit.Analyzers" Version="4.7.0" />
    <PackageVersion Include="NUnit3TestAdapter" Version="4.6.0" />
    <PackageVersion Include="Microsoft.AspNetCore.Mvc.Testing" Version="10.0.0" />
    <PackageVersion Include="Umbraco.Cms.Tests.Integration" Version="17.0.2" />
  </ItemGroup>
</Project>