{
  "name": "umbraco-community-2024",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.9",
    "npm": ">=10.1"
  },
  "scripts": {
    "dev": "vite --port 5123",
    "build": "tsc -p tsconfig.build.json && vite build",
    "build:for:cloud": "npm run build && node ./devops/copy-for-cloud.js",
    "generate:doc-contributors": "node ./devops/generate-doc-contributors.js",
    "preview": "vite preview",
    "test": "cross-env NODE_NO_WARNINGS=1 vitest --run",
    "test:ui": "cross-env NODE_NO_WARNINGS=1 vitest --ui --run",
    "test:coverage": "cross-env NODE_NO_WARNINGS=1 vitest --coverage",
    "test:ci": "cross-env NODE_NO_WARNINGS=1 vitest --run --coverage --reporter=junit --reporter=json --outputFile.junit=test-results.xml"
  },
  "dependencies": {
    "@googlemaps/markerclusterer": "^2.5.2",
    "@types/youtube-player": "^5.5.11",
    "@umbraco-ui/uui": "^1.15.0",
    "@ungap/custom-elements": "^1.3.0",
    "country-flag-emoji-polyfill": "^0.1.8",
    "lit": "^3.3.0",
    "query-selector-shadow-dom": "^1.0.1",
    "rxjs": "^7.8.1",
    "vitest": "^4.0.15",
    "youtube-player": "^5.6.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@hey-api/client-fetch": "^0.12.0",
    "@hey-api/openapi-ts": "^0.98.2",
    "@open-wc/testing": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/google.maps": "^3.54.10",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.5.9",
    "@umbraco-cms/backoffice": "^*",
    "@vitejs/plugin-basic-ssl": "^2.1.0",
    "@vitest/coverage-v8": "^4.0.15",
    "@vitest/ui": "^4.0.15",
    "cross-env": "^7.0.3",
    "glob": "^10.3.10",
    "happy-dom": "^20.0.11",
    "jsdom": "^27.3.0",
    "postcss": "^8.5.6",
    "postcss-calc": "^10.1.1",
    "postcss-mixins": "^12.1.2",
    "postcss-preset-env": "^10.2.4",
    "tsc-alias": "^1.8.8",
    "typescript": "^5.0.2",
    "vite": "^7.1.3",
    "vite-plugin-mkcert": "^1.17.3",
    "vite-tsconfig-paths": "^4.3.1",
    "web-component-analyzer": "^2.0.0-next.5"
  }
}
