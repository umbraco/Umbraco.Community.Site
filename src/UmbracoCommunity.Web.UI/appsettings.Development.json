{
  "$schema": "appsettings-schema.json",
  "OutputCache": {
    "ContentDrivenDurationSeconds": 60,
    "ExternalApiDurationSeconds": 30
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information"
    },
    "WriteTo": [
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "Console"
            }
          ]
        }
      }
    ]
  },
  "Umbraco": {
    "CMS": {
      "Global": {
        "UseHttps": false
      },
      "Content": {
        "MacroErrors": "Throw"
      },
      "Hosting": {
        "Debug": true
      },
      "ModelsBuilder": {
        "ModelsMode": "SourceCodeManual",
        "ModelsNamespace": "UmbracoCommunity.Web.Models.PublishedModels",
        "FlagOutOfDateModels": true,
        "ModelsDirectory": "~/../UmbracoCommunity.Web/Models/PublishedModels/",
        "AcceptUnsafeModelsDirectory": true
      },
      "RuntimeMinification": {
        "UseInMemoryCache": true,
        "CacheBuster": "Timestamp"
      },
      "Unattended": {
        "InstallUnattended": true,
        "UnattendedUserName": "Umbraco",
        "UnattendedUserEmail": "community@umbraco.com",
        "UnattendedUserPassword": "community!"
      }
    },
    "Licenses": {
      "Products": {
        "Umbraco.Deploy": "UMBRACO-CLOUD",
        "Umbraco.Forms": "UMBRACO-CLOUD"
      }
    }
  },
  "ConnectionStrings": {
    "umbracoDbDSN": "Data Source=|DataDirectory|/Umbraco.sqlite.db;Cache=Shared;Foreign Keys=True;Pooling=True",
    "umbracoDbDSN_ProviderName": "Microsoft.Data.Sqlite"
  }
}
