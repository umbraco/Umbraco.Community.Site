{
  "name": "Richtext Styles",
  "alias": "UmbracoCommunity.RichtextStyles",
  "extensions": [
    {
      "type": "tiptapToolbarExtension",
      "kind": "styleMenu",
      "alias": "UmbracoCommunity.Tiptap.StyleMenu",
      "name": "Richtext styles",
      "meta": {
        "alias": "richtextStyles",
        "icon": "icon-palette",
        "label": "Richtext styles"
      },
      "items": [
        {
          "label": "Headings",
          "items": [
            {
              "label": "Heading 2",
              "data": { "tag": "h2" },
              "appearance": { "icon": "icon-heading-2" }
            },
            {
              "label": "Heading 3",
              "data": { "tag": "h3" },
              "appearance": { "icon": "icon-heading-3" }
            },
            {
              "label": "Heading 4",
              "data": { "tag": "h4" },
              "appearance": { "icon": "icon-heading-4" }
            },
            {
              "label": "Heading 5",
              "data": { "tag": "h5" },
              "appearance": { "icon": "icon-heading-5" }
            }
          ]
        },
        {
          "label": "Inline",
          "items": [
            {
              "label": "Bold",
              "data": { "tag": "strong" },
              "appearance": { "style": "font-weight: bold;" }
            },
            {
              "label": "Italic",
              "data": { "tag": "em" },
              "appearance": { "style": "font-style: italic;" }
            },
            {
              "label": "Underline",
              "data": { "tag": "u" },
              "appearance": { "style": "text-decoration: underline;" }
            },
            {
              "label": "Strikethrough",
              "data": { "tag": "s" },
              "appearance": { "style": "text-decoration: line-through;" }
            }
          ]
        },
        {
          "label": "Blocks",
          "items": [
            {
              "label": "Paragraph",
              "data": { "tag": "p" }
            },
            {
              "label": "Blockquote",
              "data": { "tag": "blockquote" },
              "appearance": { "icon": "icon-blockquote" }
            },
            {
              "label": "Code block",
              "data": { "tag": "codeBlock" },
              "appearance": { "icon": "icon-code" }
            }
          ]
        },
        {
          "label": "Lists",
          "items": [
            {
              "label": "Condensed bullet list",
              "data": {
                "tag": "ul",
                "class": "no-margin"
              },
              "appearance": { "icon": "icon-bulleted-list" }
            },
            {
              "label": "Condensed numbered list",
              "data": {
                "tag": "ol",
                "class": "no-margin"
              },
              "appearance": { "icon": "icon-ordered-list" }
            }
          ]
        }
      ]
    }
  ]
}
