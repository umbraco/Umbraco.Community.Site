<Project Sdk="Microsoft.NET.Sdk.Web">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <CompressionEnabled>false</CompressionEnabled>
    <!-- Disable compression. E.g. for umbraco backoffice files. These files should be precompressed by node and not let dotnet handle it -->
  </PropertyGroup>

  <ItemGroup>
    <!-- Commented out packages will be enabled when pushing to Cloud (and Deploy.OnPrem removed) -->
    <!-- <PackageReference Include="Umbraco.Cloud.Cms" Version="17.0.0-rc2" /> -->
    
    <PackageReference Include="Umbraco.Cloud.StorageProviders.AzureBlob" Version="17.0.0-rc1" />
    <PackageReference Include="Umbraco.Cms" Version="17.0.0-rc1" />
    <PackageReference Include="Umbraco.Community.BlockPreview" Version="5.0.0-rc1" />
    <PackageReference Include="Umbraco.Deploy.OnPrem" Version="17.0.0-rc1" />
    <!-- <PackageReference Include="Umbraco.Deploy.Cloud" Version="17.0.0-rc1" /> -->
    <PackageReference Include="Umbraco.Forms" Version="17.0.0-rc1" />
    <PackageReference Include="Umbraco.Forms.Deploy" Version="17.0.0-rc1" />
	
    <PackageReference Include="Cultiv.Hangfire" Version="4.1.3" />
    <PackageReference Include="Hangfire" Version="1.8.21" />
	<PackageReference Include="Hangfire.Console" Version="1.4.3" />
    <PackageReference Include="Joonasw.AspNetCore.SecurityHeaders" Version="6.0.0" />
    <PackageReference Include="Markdig" Version="0.43.0" />	
  </ItemGroup>

  <ItemGroup>
    <!-- Opt-in to app-local ICU to ensure consistent globalization APIs across different platforms -->
    <PackageReference Include="Microsoft.ICU.ICU4C.Runtime" Version="72.1.0.3" />
    <ProjectReference Include="..\UmbracoCommunity.Web\UmbracoCommunity.Web.csproj" />
    <RuntimeHostConfigurationOption Include="System.Globalization.AppLocalIcu" Value="72.1.0.3" Condition="$(RuntimeIdentifier.StartsWith('linux')) or $(RuntimeIdentifier.StartsWith('win')) or ('$(RuntimeIdentifier)' == '' and !$([MSBuild]::IsOSPlatform('osx')))" />
  </ItemGroup>

  <PropertyGroup>
    <!-- Razor files are needed for the backoffice to work correctly -->
    <CopyRazorGenerateFilesToPublishDirectory>true</CopyRazorGenerateFilesToPublishDirectory>
  </PropertyGroup>

</Project>
