{
  "$schema": "appsettings-schema.json",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    }
  },
  "Umbraco": {
    "CMS": {
      "Global": {
        "Id": "301fd2c6-952c-4f45-92cc-8d5e0e9bbd7c",
        "UseHttps": true,
        "NoNodesViewPath": "~/umbraco/UmbracoWebsite/Deploy/NoNodes.cshtml",
        "SanitizeTinyMce": true
      },
      "Content": {
        "AllowEditInvariantFromNonDefault": true,
        "ContentVersionCleanupPolicy": {
          "EnableCleanup": true
        }
      },
      "Unattended": {
        "UpgradeUnattended": true
      },
      "Security": {
        "AllowConcurrentLogins": false
      },
      "ModelsBuilder": {
        "ModelsMode": "Nothing"
      },
      "Runtime": {
        "Mode": "BackofficeDevelopment"
      }
    }
  },
  "BlockPreview": {
    "BlockGrid": {
      "Enabled": true,
      "ContentTypes": [],
      "ViewLocations": [
        "/Views/Partials/Blocks/{0}.cshtml"
      ],
      "Stylesheet": "/css/styles.css"
    },
    "BlockList": {
      "Enabled": false
    },
    "RichText": {
      "Enabled": true,
      "ViewLocations": [
        "/Views/Partials/Blocks/{0}.cshtml"
      ],
      "Stylesheet": "/css/styles.css"
    }
  },
  "GitHubSync": {
    "Token": "",
    "Organization": "umbraco",
    "RecentDays": 7,
    "Repositories": [
      {
        "Name": "Umbraco-CMS",
        "NuGetPackageIds": [
          "Umbraco.Cms",
          "UmbracoCms"
        ],
        "AnnouncementsPrefix": "cms"
      },
      {
        "Name": "Umbraco.UI"
      },
      {
        "Name": "Announcements"
      }
    ],
    "HqOnlyTeams": [
      "hq-only-teams"
    ]
  },
  "ConnectionStrings": {
  }
}