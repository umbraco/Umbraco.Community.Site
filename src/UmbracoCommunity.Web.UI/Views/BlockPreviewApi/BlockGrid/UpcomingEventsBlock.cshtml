@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<Umbraco.Cms.Core.Models.Blocks.BlockGridItem<UpcomingEventsBlock, SettingsUpcomingEventsBlock>>

@{
    var hasBg = Model.Settings.HasBg();
    var bgIsDark = hasBg && Model.Settings.IsDark();
    var blockStyle = hasBg ? $"--block-background-color: {Model.Settings?.BackgroundColour?.Color}" : null;
}

<div class="dc-upcoming-events-preview @(hasBg ? "has-bg" : string.Empty) @(bgIsDark ? "bg-dark" : string.Empty)" style="@blockStyle">
    <h3>@(string.IsNullOrWhiteSpace(Model.Content.Title) ? "Upcoming Events" : Model.Content.Title)</h3>
    @if (!Model.Content.Subtitle.IsEmptyHtmlString())
    {
        <div class="dc-upcoming-events-preview__subtitle">
            @Html.Raw(Model.Content.Subtitle?.ToHtmlString())
        </div>
    }
    <p class="dc-upcoming-events-preview__note">
        Live preview shows up to <strong>@Model.Content.MaxItems</strong> upcoming Umbraco community events from
        <a href="https://umbracalendar.com" rel="noopener" target="_blank">umbracalendar.com</a> on the front end.
    </p>
</div>
