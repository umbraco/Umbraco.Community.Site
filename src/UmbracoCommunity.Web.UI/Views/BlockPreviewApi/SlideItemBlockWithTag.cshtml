@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<Umbraco.Cms.Core.Models.Blocks.BlockGridItem<SlideItemBlockWithTag>>

<div style="padding: 10px; border: 1px solid #e0e0e0; border-radius: 4px; margin-bottom: 6px;">
    @if (!string.IsNullOrEmpty(Model.Content.Tag))
    {
        <span style="display: inline-block; background: #f0f0f0; padding: 2px 8px; border-radius: 3px; font-size: 12px; margin-bottom: 4px;">@Model.Content.Tag</span>
    }
    @if (!string.IsNullOrEmpty(Model.Content.Title))
    {
        <h4 style="margin: 0 0 4px;">@Model.Content.Title</h4>
    }
    @if (!string.IsNullOrEmpty(Model.Content.Content))
    {
        <p style="margin: 0; font-size: 13px; color: #666;">@Model.Content.Content</p>
    }
</div>
