@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<Umbraco.Cms.Core.Models.Blocks.BlockGridItem<SlideItemBlockWithIcon>>

<div style="padding: 10px; border: 1px solid #e0e0e0; border-radius: 4px; margin-bottom: 6px; display: flex; align-items: center; gap: 10px;">
    @if (Model.Content.Icon != null)
    {
        <img src="@Model.Content.Icon.MediaUrl()" alt="" style="width: 32px; height: 32px; object-fit: contain;" />
    }
    <div>
        @if (!string.IsNullOrEmpty(Model.Content.Title))
        {
            <h4 style="margin: 0 0 4px;">@Model.Content.Title</h4>
        }
        @if (!string.IsNullOrEmpty(Model.Content.Content))
        {
            <p style="margin: 0; font-size: 13px; color: #666;">@Model.Content.Content</p>
        }
    </div>
</div>
