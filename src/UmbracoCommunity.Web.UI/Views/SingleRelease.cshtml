@using UmbracoCommunity.Web.Models.Pages
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<ReleasePageViewModel>
@{
    Layout = "LayoutReleases.cshtml";
    ViewData["PageTitle"] = $"{Model.Repository} v{Model.Version} release notes";
    if (Model.Releases.FirstOrDefault() != null)
    {
        ViewData["PageDescription"] = $"{Model.Repository} v{Model.Version} has {Model.Releases.FirstOrDefault().TotalCount} bug fixes and improvements.";
    }
}

<div class="sticky-version-bar" id="stickyVersionBar">
    <div class="sticky-version-content">
        @if (!string.IsNullOrEmpty(Model.Repository) && Model.ReleaseInfo != null)
        {
            <div class="sticky-version-title">
                <span class="sticky-version-label">Viewing:</span>
                <span>@Model.Repository v@(Model.ReleaseInfo.Version)</span>
            </div>
            @if (Model.ReleaseInfo.ReleaseDate.HasValue)
            {
                <div class="sticky-version-label">
                    @if (Model.ReleaseInfo.IsReleased)
                    {
                        <span>Released: @Model.ReleaseInfo.FormattedReleaseDate</span>
                    }
                    else
                    {
                        <span>Target: @Model.ReleaseInfo.FormattedReleaseDate</span>
                    }
                </div>
            }
        }
    </div>
</div>

<div class="dc-block-list releases-container">
    @await Html.PartialAsync("~/Views/Partials/ReleaseOverview/_SingleReleaseDetails.cshtml", Model)
</div>
