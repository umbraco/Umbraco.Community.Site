@inherits UmbracoViewPage<DigitalSignagePage>

@{
    Layout = null;

    var signageNowRaw = Context.Request.Query["signage-now"].ToString();
    var siteLogo = Model.GetSiteSettings()?.HeaderLogo;
    var contentGrid = Model.ContentBlocks.ParseBlockGrid();
}

<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentCulture.Name">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@Model.Name</title>
    <link rel="stylesheet" vite-href="digital-signage" asp-add-nonce="true" />
</head>
<body class="dc-signage">
    <div class="dc-signage__clock @(string.IsNullOrEmpty(signageNowRaw) ? string.Empty : "is-simulated")"
         data-signage-clock
         data-signage-now="@signageNowRaw">
        <span class="dc-signage__clock-time" data-clock-time>--:--</span>
        <span class="dc-signage__clock-date" data-clock-date>—</span>
    </div>
    @if (siteLogo != null)
    {
        <div class="dc-signage__logo">
            <partial name="~/Views/Partials/Components/Logo.cshtml" model="siteLogo" />
        </div>
    }
    <main class="dc-signage__main">
        <partial name="~/Views/Partials/Components/ContentBlocks.cshtml" model="contentGrid" />
    </main>
    <script vite-src="digital-signage" vite-client="true" asp-add-nonce="true"></script>
</body>
</html>
