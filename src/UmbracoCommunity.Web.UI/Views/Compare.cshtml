@using Markdig
@using UmbracoCommunity.Web.Models.Pages
@using UmbracoCommunity.Web.Features.ReleaseOverview.Models
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<ComparePageViewModel>
@{
    Layout = "LayoutReleases.cshtml";
    ViewData["PageTitle"] = $"Compare Umbraco releases";
    if(Model.FromVersion != null || Model.ToVersion != null)
    {
        ViewData["PageTitle"] = $"Changes after v{Model.FromVersion}, up to (and including) v{Model.ToVersion}";
    }
    
    if(Model.FromVersion != null || Model.ToVersion != null)
    {
        ViewData["PageDescription"] = $"Comparing change in Umbraco after v{Model.FromVersion}, up to (and including) v{Model.ToVersion}";
    }
}

@if (!string.IsNullOrEmpty(Model.LowestVersion) && !string.IsNullOrEmpty(Model.HighestVersion))
{
    <div class="sticky-version-bar" id="stickyVersionBar">
    <div class="sticky-version-content">
    <div class="sticky-version-title">
    <span class="sticky-version-label">Comparing:</span>
    <span>v@(Model.LowestVersion) → v@(Model.HighestVersion)</span>
            </div>
            <div class="sticky-version-label">
                <span>@Model.FeatureCount features, @Model.BreakingChangesCount breaking changes, @Model.IssuesAndTasksCount issues & tasks</span>
            </div>
        </div>
    </div>
}

<div class="dc-block-list releases-container compare-page">
    <h1 class="compare-title">Compare Releases</h1>

    <div class="compare-filters">
        <form method="get" action="/compare" id="compareForm">
            <div class="compare-dropdowns">
                <div class="compare-dropdown-group">
                    <label for="fromVersion">From version:</label>
                    <select id="fromVersion" name="from">
                        <option value="">Select version</option>
                        @foreach (var version in Model.AvailableVersions)
                        {
                            @if (Model.FromVersion == version.Version)
                            {
                                <option value="@version.Version" selected>@version.Version</option>
                            }
                            else
                            {
                                <option value="@version.Version">@version.Version</option>
                            }
                        }
                    </select>
                </div>

                <div class="compare-dropdown-group">
                    <label for="toVersion">To version:</label>
                    <select id="toVersion" name="to">
                        <option value="">Select version</option>
                        @foreach (var version in Model.AvailableVersions)
                        {
                            @if (Model.ToVersion == version.Version)
                            {
                                <option value="@version.Version" selected>@version.Version</option>
                            }
                            else
                            {
                                <option value="@version.Version">@version.Version</option>
                            }
                        }
                    </select>
                </div>

                <button type="submit" class="compare-button">Compare</button>
            </div>

            <div class="compare-checkbox-group">
                <label>
                    <input type="checkbox"
                           id="includePreReleases"
                           name="includePreReleases"
                           value="true"
                           @if (Model.IncludePreReleases) { <text>checked="checked"</text> } />
                    Include pre-release versions
                </label>
                <label>
                    <input type="checkbox"
                           id="showNotesOnly"
                           name="notes"
                           value="1"
                           @if (Model.ShowNotesOnly) { <text>checked="checked"</text> } />
                    Show only breaking changes and release notes
                </label>
            </div>
        </form>
    </div>

    @if (!string.IsNullOrEmpty(Model.LowestVersion) && !string.IsNullOrEmpty(Model.HighestVersion))
    {
        @if (Model.CombinedContributors != null)
        {
            @await Html.PartialAsync("~/Views/Partials/ReleaseOverview/_ContributorsSection.cshtml", new ContributorsSectionViewModel
            {
                ReleaseGroup = Model.CombinedContributors,
                SelectedRepo = "Umbraco-CMS"
            })
        }

        @foreach (var versionGroup in Model.VersionGroups)
        {
            <div class="release-group">
                <div class="release-notes-header">
                    <h2>Changes in v@(versionGroup.Version)</h2>
                    @if (!Model.ShowNotesOnly)
                    {
                        <p>
                            <strong>@versionGroup.Features.Count</strong> new features,
                            <strong>@versionGroup.BreakingChanges.Count</strong> breaking changes, and
                            <strong>@versionGroup.IssuesAndTasks.Count</strong> issues & tasks were implemented
                        </p>
                    }
                    else
                    {
                        <p>
                            <strong>@versionGroup.BreakingChanges.Count</strong> breaking changes
                        </p>
                    }
                    <p class="release-nuget-link">
                        Make sure to read the <a href="https://docs.umbraco.com/umbraco-cms/fundamentals/setup/upgrading/version-specific" target="_blank">version specific upgrades notes</a> for guidance.
                    </p>
                </div>

                @if (!string.IsNullOrEmpty(versionGroup.Description))
                {
                    <div class="release-description">
                        @Html.Raw(Markdig.Markdown.ToHtml(versionGroup.Description, new MarkdownPipelineBuilder().UseAdvancedExtensions().Build()))
                    </div>
                }

                @if (!versionGroup.Features.Any() && !versionGroup.BreakingChanges.Any() && !versionGroup.IssuesAndTasks.Any())
                {
                    <div class="release-categories">
                        <div class="empty-state">
                            <p>No known issues or PRs for this version, there may be more info on GitHub: <a href="https://github.com/umbraco/Umbraco-CMS/releases/tag/release-@(versionGroup.Version)" target="_blank">https://github.com/umbraco/Umbraco-CMS/releases/tag/release-@(versionGroup.Version)</a></p>
                        </div>
                    </div>
                }
                else
                {
                    <div class="release-categories">
                        @if (!Model.ShowNotesOnly && versionGroup.Features.Any())
                        {
                            <details class="release-category" open>
                                <summary>
                                    Features
                                    <uui-badge color="default" look="primary">@versionGroup.Features.Count</uui-badge>
                                </summary>
                                <div class="pr-list">
                                    @foreach (var pr in versionGroup.Features)
                                    {
                                        @await Html.PartialAsync("~/Views/Partials/ReleaseOverview/_CompareItem.cshtml", new PullRequestItemViewModel
                                        {
                                            PullRequest = pr,
                                            UmbracoLogoPath = Model.UmbracoLogoPath,
                                            LabelCheck = Model.LabelCheck
                                        })
                                    }
                                </div>
                            </details>
                        }

                        @if (versionGroup.BreakingChanges.Any())
                        {
                            <details class="release-category" open>
                                <summary>
                                    Breaking changes
                                    <uui-badge color="default" look="primary">@versionGroup.BreakingChanges.Count</uui-badge>
                                </summary>
                                <div class="pr-list">
                                    @foreach (var pr in versionGroup.BreakingChanges)
                                    {
                                        @await Html.PartialAsync("~/Views/Partials/ReleaseOverview/_CompareItem.cshtml", new PullRequestItemViewModel
                                        {
                                            PullRequest = pr,
                                            UmbracoLogoPath = Model.UmbracoLogoPath,
                                            LabelCheck = Model.LabelCheck
                                        })
                                    }
                                </div>
                            </details>
                        }

                        @if (!Model.ShowNotesOnly && versionGroup.IssuesAndTasks.Any())
                        {
                            <details class="release-category" open>
                                <summary>
                                    Issues & Tasks
                                    <uui-badge color="default" look="primary">@versionGroup.IssuesAndTasks.Count</uui-badge>
                                </summary>
                                <div class="pr-list">
                                    @foreach (var pr in versionGroup.IssuesAndTasks)
                                    {
                                        @await Html.PartialAsync("~/Views/Partials/ReleaseOverview/_CompareItem.cshtml", new PullRequestItemViewModel
                                        {
                                            PullRequest = pr,
                                            UmbracoLogoPath = Model.UmbracoLogoPath,
                                            LabelCheck = Model.LabelCheck
                                        })
                                    }
                                </div>
                            </details>
                        }
                    </div>
                }
            </div>
        }

        @if (!Model.VersionGroups.Any())
        {
            <div class="empty-state">
                <p>No related PRs or issues found between these versions.</p>
            </div>
        }
    }
    else if (!string.IsNullOrEmpty(Model.FromVersion) || !string.IsNullOrEmpty(Model.ToVersion))
    {
        <div class="empty-state">
            <p>Please select both versions to compare.</p>
        </div>
    }
</div>
