@using UmbracoCommunity.Web.Models.Pages
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<ReleasesHomePageViewModel>
@{
	Layout = "LayoutReleases.cshtml";
}

<div class="dc-block-list releases-container">
    @if (string.IsNullOrEmpty(Model.SelectedRepo))
    {
        @await Html.PartialAsync("~/Views/Partials/ReleaseOverview/_ReleasesOverview.cshtml", Model)
    }
    else if (!string.IsNullOrEmpty(Model.SelectedRepo))
    {
        @await Html.PartialAsync("~/Views/Partials/ReleaseOverview/_ReleaseDetails.cshtml", Model)
    }
</div>

