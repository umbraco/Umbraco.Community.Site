@{
	Layout = null;
}
@using UmbracoCommunity.Web.Models.Pages
@inherits UmbracoViewPage<PageViewModelBase>

<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentCulture.Name">
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    @{
        var pageTitle = ViewData["PageTitle"] as string ?? "Umbraco Releases";
        var pageDescription = ViewData["PageDescription"] as string ?? "Explore Umbraco CMS releases, version history, and release notes. Track features, improvements, and updates across all Umbraco versions.";
        var pageUrl = $"{Context.Request.Scheme}://{Context.Request.Host}{Context.Request.Path}{Context.Request.QueryString}";
        var imageUrl = $"{Context.Request.Scheme}://{Context.Request.Host}/img/umbraco_logo.png";
    }
    <meta name="description" content="@pageDescription">
    <title>@pageTitle</title>
    
    <!-- Open Graph / Facebook / LinkedIn / Discord -->
    <meta property="og:type" content="website">
    <meta property="og:url" content="@pageUrl">
    <meta property="og:title" content="@pageTitle">
    <meta property="og:description" content="@pageDescription">
    <meta property="og:image" content="@imageUrl">
    <meta property="og:site_name" content="Umbraco Releases">

    <!-- Twitter -->
    <meta name="twitter:card" content="summary">
    <meta name="twitter:url" content="@pageUrl">
    <meta name="twitter:title" content="@pageTitle">
    <meta name="twitter:description" content="@pageDescription">
    <meta name="twitter:image" content="@imageUrl">

    <link rel="stylesheet" vite-href="index" asp-add-nonce="true" />
    <link rel="stylesheet" vite-href="@Model.ContentTypeAlias" />

    @RenderSection("Links", required: false)
    @RenderSection("CSS", required: false)
</head>

<body class="@GetBodyClasses()">
    <partial name="~/Views/Partials/Components/MenuReleases.cshtml" for="Menu" />

    <main>
        @RenderBody()
    </main>

    <partial name="~/Views/Partials/Components/FooterReleases.cshtml" />

    <script vite-src="index" vite-client="true" asp-add-nonce="true"></script>
    <script vite-src="@Model.ContentTypeAlias" asp-add-nonce="true"></script>

    @RenderSection("JS", required: false)
    @Html.PageScripts()
</body>

</html>

@{
    string GetBodyClasses()
    {
        var bodyClasses = new List<string> { $"document-{Model.ContentTypeAlias}" };
        return string.Join(" ", bodyClasses);
    }
}
