@using Umbraco.Cms.Core.Models
@using static UmbracoCommunity.Web.Extensions.HtmlHelperExtensions
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<Umbraco.Cms.Core.Models.Blocks.BlockGridItem<HeroBannerWithImageSlider>>

@if (!string.IsNullOrWhiteSpace(Model.Content.Headline))
{
    <div class="dc-hero-image-slider">
        <div class="dc-hero-image-slider__content">
            @if (!string.IsNullOrEmpty(Model.Content.Tagline))
            {
                <p class="dc-hero-image-slider__tagline">@Model.Content.Tagline</p>
            }
            <h2>@Model.Content.Headline</h2>
            @if (!Model.Content.BodyText.IsEmptyHtmlString())
            {
                <div class="dc-hero-image-slider__body">
                    @Html.Raw(Model.Content.BodyText?.ToHtmlString())
                </div>
            }
            @if (Model.Content.CallToActionLinks?.Any() ?? false)
            {
                <div class="dc-hero-image-slider__ctas">
                    @{
                        RenderCtaButtons(Model.Content.CallToActionLinks.ToList());
                    }
                </div>
            }
        </div>
        @if (Model.Content.SliderImages?.Any() ?? false)
        {
            <dc-image-slider>
                @foreach (var image in Model.Content.SliderImages)
                {
                    <img src="@image.MediaUrl()"
                         alt="@image.Name"
                         loading="lazy"
                         draggable="false" />
                }
            </dc-image-slider>
        }
    </div>
}

@functions {
    void RenderCtaButtons(List<Link> ctaButtons)
    {
        var themes = new ButtonLinkTheme[] {
            ButtonLinkTheme.Blue,
            ButtonLinkTheme.TransparentBlue
        };

        for (var i = 0; i < ctaButtons.Count; i++)
        {
            var cta = ctaButtons[i];
            @Html.RenderButtonCTA(cta.Url, cta.Name, cta.Target, cta.Name, themes[i])
        }
    }
}
