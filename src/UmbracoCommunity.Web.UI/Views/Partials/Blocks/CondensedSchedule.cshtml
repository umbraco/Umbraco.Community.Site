@using System.Text.Json
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<Umbraco.Cms.Core.Models.Blocks.BlockGridItem<UmbracoCommunity.Web.Models.PublishedModels.CondensedSchedule>>
@{
    var scheduleJson = Model?.Content?.EventSchedule?.RootElement.GetRawText() ?? "";
}

@if (!string.IsNullOrWhiteSpace(scheduleJson))
{
    if (Context.Request.IsBlockPreviewRequest())
    {
        // Server-side HTML preview for the backoffice block editor
        var root = Model!.Content!.EventSchedule!.RootElement;
        var settings = root.GetProperty("settings");
        var startHour = settings.GetProperty("startHour").GetInt32();
        var endHour = settings.GetProperty("endHour").GetInt32();
        var days = root.GetProperty("days");
        var events = root.GetProperty("events");
        var venues = root.GetProperty("venues");

        var hourHeight = 40;
        var eventGap = 2;
        var totalHours = endHour - startHour;
        var gridHeight = totalHours * hourHeight;

        // Build venue lookup
        var venueColors = new Dictionary<string, string>();
        var venueNames = new Dictionary<string, string>();
        foreach (var v in venues.EnumerateArray())
        {
            var alias = v.GetProperty("alias").GetString() ?? "";
            venueColors[alias] = v.GetProperty("color").GetString() ?? "#ccc";
            venueNames[alias] = v.GetProperty("name").GetString() ?? alias;
        }

        // Helper to check if color is light
        static bool IsLight(string hex)
        {
            hex = hex.TrimStart('#');
            if (hex.Length == 3) hex = $"{hex[0]}{hex[0]}{hex[1]}{hex[1]}{hex[2]}{hex[2]}";
            var num = Convert.ToInt32(hex, 16);
            int r = (num >> 16) & 255, g = (num >> 8) & 255, b = num & 255;
            return (0.299 * r + 0.587 * g + 0.114 * b) / 255 > 0.5;
        }

        <div style="display:flex; border:1px solid #e5e7eb; border-radius:6px; overflow-x:auto; font-family:sans-serif; font-size:12px;">
            @* Time gutter *@
            <div style="flex-shrink:0; width:55px; padding-top:32px; border-right:1px solid #e5e7eb;">
                @for (var h = startHour; h < endHour; h++)
                {
                    var hour12 = h % 24;
                    var period = hour12 < 12 ? "AM" : "PM";
                    var display = hour12 == 0 ? 12 : hour12 > 12 ? hour12 - 12 : hour12;
                    <div style="height:@(hourHeight)px; display:flex; align-items:flex-start; justify-content:flex-end; padding:2px 6px 0 0; box-sizing:border-box; color:#1b264f;">
                        <span style="font-size:12px; font-weight:600;">@display</span><span style="font-size:8px; margin-top:1px;">@period</span>
                    </div>
                }
            </div>
            @* Day columns *@
            @{
                var dayIndex = 0;
            }
            @foreach (var day in days.EnumerateArray())
            {
                var label = day.GetProperty("label").GetString() ?? "";
                <div style="flex:1; min-width:100px; border-right:1px solid #e5e7eb;">
                    <div style="height:32px; display:flex; align-items:center; justify-content:center; font-weight:600; font-size:12px; color:#1b264f; border-bottom:1px solid #e5e7eb;">
                        @label
                    </div>
                    <div style="position:relative; height:@(gridHeight)px;">
                        @* Hour rows *@
                        @for (var h = 0; h < totalHours; h++)
                        {
                            <div style="height:@(hourHeight)px; box-sizing:border-box; border-bottom:1px solid #eee;"></div>
                        }
                        @* Events for this day *@
                        @{
                            // Collect events for this day
                            var dayEvents = new List<JsonElement>();
                            foreach (var evt in events.EnumerateArray())
                            {
                                if (evt.GetProperty("dayIndex").GetInt32() == dayIndex)
                                {
                                    dayEvents.Add(evt);
                                }
                            }

                            // Sort by start time then columnIndex
                            dayEvents.Sort((a, b) =>
                            {
                                var aTime = a.GetProperty("startTime").GetString() ?? "00:00";
                                var bTime = b.GetProperty("startTime").GetString() ?? "00:00";
                                var cmp = string.Compare(aTime, bTime, StringComparison.Ordinal);
                                if (cmp != 0) return cmp;
                                var aCol = a.TryGetProperty("columnIndex", out var ac) ? ac.GetInt32() : 0;
                                var bCol = b.TryGetProperty("columnIndex", out var bc) ? bc.GetInt32() : 0;
                                return aCol.CompareTo(bCol);
                            });

                            // Layout: assign columns respecting columnIndex preference
                            var columns = new List<(int endMin, List<JsonElement> evts)>();
                            var evtColumnMap = new Dictionary<int, int>(); // index in dayEvents -> column

                            for (var i = 0; i < dayEvents.Count; i++)
                            {
                                var evt = dayEvents[i];
                                var st = evt.GetProperty("startTime").GetString() ?? "00:00";
                                var parts = st.Split(':');
                                var startMin = int.Parse(parts[0]) * 60 + int.Parse(parts[1]);
                                var et = evt.GetProperty("endTime").GetString() ?? "00:00";
                                var eParts = et.Split(':');
                                var endMin = int.Parse(eParts[0]) * 60 + int.Parse(eParts[1]);
                                var preferred = evt.TryGetProperty("columnIndex", out var ci) ? ci.GetInt32() : -1;

                                var placed = false;
                                // Try preferred column
                                if (preferred >= 0)
                                {
                                    while (columns.Count <= preferred)
                                        columns.Add((0, new List<JsonElement>()));
                                    if (columns[preferred].endMin <= startMin)
                                    {
                                        columns[preferred] = (endMin, columns[preferred].evts);
                                        columns[preferred].evts.Add(evt);
                                        evtColumnMap[i] = preferred;
                                        placed = true;
                                    }
                                }
                                if (!placed)
                                {
                                    for (var col = 0; col < columns.Count; col++)
                                    {
                                        if (columns[col].endMin <= startMin)
                                        {
                                            columns[col] = (endMin, columns[col].evts);
                                            columns[col].evts.Add(evt);
                                            evtColumnMap[i] = col;
                                            placed = true;
                                            break;
                                        }
                                    }
                                }
                                if (!placed)
                                {
                                    evtColumnMap[i] = columns.Count;
                                    columns.Add((endMin, new List<JsonElement> { evt }));
                                }
                            }

                            for (var i = 0; i < dayEvents.Count; i++)
                            {
                                var evt = dayEvents[i];
                                var title = evt.GetProperty("title").GetString() ?? "";
                                var subtitle = evt.TryGetProperty("subtitle", out var sub) ? sub.GetString() ?? "" : "";
                                var venueAlias = evt.GetProperty("venueAlias").GetString() ?? "";
                                var notIncluded = evt.TryGetProperty("notIncludedInTicket", out var ni) && ni.GetBoolean();
                                var st = evt.GetProperty("startTime").GetString() ?? "00:00";
                                var sParts = st.Split(':');
                                var sMin = int.Parse(sParts[0]) * 60 + int.Parse(sParts[1]);
                                var et2 = evt.GetProperty("endTime").GetString() ?? "00:00";
                                var eParts2 = et2.Split(':');
                                var eMin = int.Parse(eParts2[0]) * 60 + int.Parse(eParts2[1]);

                                var bgColor = venueColors.GetValueOrDefault(venueAlias, "#ccc");
                                var txtColor = IsLight(bgColor) ? "#283a97" : "#ffffff";

                                var col = evtColumnMap[i];
                                // Count overlapping columns for this event
                                var overlapCols = 0;
                                foreach (var c in columns)
                                {
                                    var hasOverlap = c.evts.Any(e =>
                                    {
                                        var es = e.GetProperty("startTime").GetString() ?? "00:00";
                                        var ep = es.Split(':');
                                        var esm = int.Parse(ep[0]) * 60 + int.Parse(ep[1]);
                                        var ee = e.GetProperty("endTime").GetString() ?? "00:00";
                                        var eep = ee.Split(':');
                                        var eem = int.Parse(eep[0]) * 60 + int.Parse(eep[1]);
                                        return esm < eMin && eem > sMin;
                                    });
                                    if (hasOverlap) overlapCols++;
                                }

                                var topPx = ((sMin - startHour * 60) / 60.0) * hourHeight + eventGap;
                                var heightPx = ((eMin - sMin) / 60.0) * hourHeight - eventGap * 2;
                                var widthPct = 100.0 / overlapCols;
                                var leftPct = col * widthPct;

                                <div style="position:absolute; top:@(topPx.ToString("F1"))px; height:@(heightPx.ToString("F1"))px; left:calc(@(leftPct.ToString("F1"))% + 2px); width:calc(@(widthPct.ToString("F1"))% - 4px); background:@bgColor; color:@txtColor; border-radius:8px; padding:3px 5px; overflow:hidden; box-sizing:border-box; line-height:1.3;"
                                    title="@title@(string.IsNullOrEmpty(subtitle) ? "" : $" - {subtitle}")">
                                    <div style="font-weight:600; font-size:11px; overflow:hidden;">@title@(notIncluded ? " *" : "")</div>
                                    @if (!string.IsNullOrEmpty(subtitle))
                                    {
                                        <div style="font-size:10px; font-style:italic; opacity:0.85; overflow:hidden;">@subtitle</div>
                                    }
                                </div>
                            }
                        }
                    </div>
                </div>
                dayIndex++;
            }
        </div>
        @* Legend *@
        <div style="display:flex; flex-wrap:wrap; gap:8px 14px; padding:8px 0 0; font-size:11px;">
            @foreach (var v in venues.EnumerateArray())
            {
                var name = v.GetProperty("name").GetString() ?? "";
                var color = v.GetProperty("color").GetString() ?? "#ccc";
                <div style="display:flex; align-items:center; gap:5px;">
                    <span style="display:inline-block; width:11px; height:11px; border-radius:2px; background:@color;"></span>
                    <span style="color:#1b264f;">@name</span>
                </div>
            }
        </div>
    }
    else
    {
        <dc-event-schedule data="@Html.Raw(System.Web.HttpUtility.HtmlAttributeEncode(scheduleJson))"></dc-event-schedule>
    }
}
