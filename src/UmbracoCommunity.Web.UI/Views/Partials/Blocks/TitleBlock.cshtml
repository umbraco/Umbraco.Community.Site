@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<Umbraco.Cms.Core.Models.Blocks.BlockGridItem<TitleBlock>>

@if (!string.IsNullOrWhiteSpace(Model.Content.Title))
{
    <div class="dc-headline__container">
        @if (!string.IsNullOrWhiteSpace(Model.Content.Text))
        {
            <span>@Model.Content.Text</span>
        }
        <h2>@Model.Content.Title</h2>
    </div>
}