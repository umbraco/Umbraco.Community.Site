@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<Umbraco.Cms.Core.Models.Blocks.BlockGridItem<TitleBlock, SettingsTitleBlock>>

@if (Model.Content.Title != null)
{
    bool hasBg = Model.Settings.HasBg();
    bool bgIsDark = hasBg && Model.Settings.IsDark();

    <div class="dc-title-block justify-center @(hasBg ? "has-bg" : "transparent") @(bgIsDark ? "bg-dark" : string.Empty)" id="@Model.Content.IdHash">
        @if (hasBg)
        {
            <style asp-add-nonce="true">
                # @Model.Content.IdHash {
                    --block-background-color: @Model.Settings?.BackgroundColour?.Color;
                }
            </style>
        }

        @if (!string.IsNullOrWhiteSpace(Model.Content.Title))
        {
            <h2 class="block-title">@Model.Content.Title</h2>
        }
        @if (Model.Content.Text != null)
        {
            <div class="block-subtitle">
                @Html.Raw(Model.Content.Text?.ToHtmlString())
            </div>
        }
    </div>
}