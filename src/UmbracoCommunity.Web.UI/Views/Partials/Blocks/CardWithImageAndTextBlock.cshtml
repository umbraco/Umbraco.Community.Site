@using Umbraco.Cms.Core.Models.Blocks
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<Umbraco.Cms.Core.Models.Blocks.BlockGridItem<CardWithImageAndTextBlock>>

@{
    var gridCols = Model.GridColumns ?? 12;
}

@if (Model.Content.CardContent != null && Model.Content.CardContent.Any())
{
    var widthPercent = (Model.ColumnSpan / (double)gridCols) * 100;
    @if (Model.Content.Link != null)
    {
        <a id="@Model.Content.IdHash" class="dc-boxes-row__item" href="@Model.Content.Link.Url" target="@Model.Content.Link.Target" title="@Model.Content.Link.Name">
            @{
                RenderCard(Model.Content.CardContent);
                await RenderStyle(widthPercent, Model.Content.IdHash);
            }
        </a>
    }
    else
    {
        <div id="@Model.Content.IdHash" class="dc-boxes-row__item">
            @{
                RenderCard(Model.Content.CardContent);
                await RenderStyle(widthPercent, Model.Content.IdHash);
            }
        </div>
    }
}

@functions {
    void RenderCard(BlockListModel elements)
    {
        @foreach (var contentItem in elements)
        {
            switch (contentItem.Content.ContentType.Alias)
            {
                case ImageBlock.ModelTypeAlias:
                    var imageItem = contentItem.Content as ImageBlock;
                    <img srcset="@imageItem.Image.GetCropUrl("mobile") 386w, @imageItem.Image.GetCropUrl("desktop") 906w"
                         sizes="(max-width: 400px) 386px, 906px"
                         src="@imageItem.Image.GetCropUrl("desktop")" alt="@imageItem.AltText"
                         loading="lazy" />
                    break;
                case TextBlock.ModelTypeAlias:
                    var textItem = contentItem.Content as TextBlock;
                    <div class="dc-boxes-row__item-content">
                        @Html.Raw(textItem.Text)
                    </div>
                    break;
            }
        }
    }

    async Task RenderStyle(double width, string idHash)
    {
        <style asp-add-nonce="true">
            @@media (min-width: 1216px) {
                .dc-boxes-row__items #@(idHash) {
                    width: @($"{width}%");
                    max-width: @($"{width}%");
                }
            }
        </style>
    }
}