@using System.Globalization
@using Umbraco.Cms.Core.Models.Blocks
@using UmbracoCommunity.Web.Features.Feeds.Calendar
@using UmbracoCommunity.Web.Models.PublishedModels
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<BlockGridItem<UpcomingEventsBlock, SettingsUpcomingEventsBlock>>
@inject ICalendarFeedService FeedService

@{
    var maxItems = Math.Max(1, Model.Content.MaxItems);
    var allEvents = await FeedService.GetUpcomingEventsAsync();
    var events = allEvents.Take(maxItems).ToList();
}

@if (events.Count == 0 && string.IsNullOrWhiteSpace(Model.Content.Headline))
{
    return;
}

<section class="dc-upcoming-events dc-upcoming-events--@Model.Content.IdHash">
    @if (!string.IsNullOrWhiteSpace(Model.Content.Headline))
    {
        <h2 class="dc-upcoming-events__headline">@Model.Content.Headline</h2>
    }

    @if (events.Count > 0)
    {
        <ul class="dc-upcoming-events__list">
            @foreach (var ev in events)
            {
                var startIso = ev.StartsAt.ToString("o", CultureInfo.InvariantCulture);
                var endIso = ev.EndsAt.ToString("o", CultureInfo.InvariantCulture);
                var sameDay = ev.StartsAt.Date == ev.EndsAt.Date && ev.StartsAt.Offset == ev.EndsAt.Offset;
                var tz = FormatOffset(ev.StartsAt.Offset);

                <li class="dc-upcoming-events__item">
                    <a class="dc-upcoming-events__title" href="@ev.Url" rel="noopener" target="_blank">
                        @ev.Title
                    </a>
                    <div class="dc-upcoming-events__meta">
                        <dc-event-time start="@startIso" end="@endIso">
                            <time datetime="@startIso">
                                @ev.StartsAt.ToString("ddd d MMM yyyy", CultureInfo.InvariantCulture),
                                @ev.StartsAt.ToString("HH:mm", CultureInfo.InvariantCulture)
                            </time>
                            <span class="dc-upcoming-events__range-sep"> — </span>
                            <time datetime="@endIso">
                                @if (sameDay)
                                {
                                    @ev.EndsAt.ToString("HH:mm", CultureInfo.InvariantCulture)
                                }
                                else
                                {
                                    @ev.EndsAt.ToString("ddd d MMM yyyy", CultureInfo.InvariantCulture)<text>, </text>@ev.EndsAt.ToString("HH:mm", CultureInfo.InvariantCulture)
                                }
                            </time>
                            <span class="dc-upcoming-events__tz"> (@tz)</span>
                        </dc-event-time>
                        @if (!string.IsNullOrWhiteSpace(ev.Location))
                        {
                            <span class="dc-upcoming-events__location">· @ev.Location</span>
                        }
                        @if (!string.IsNullOrWhiteSpace(ev.Organizer))
                        {
                            <span class="dc-upcoming-events__organizer">· @ev.Organizer</span>
                        }
                    </div>
                    <div class="dc-upcoming-events__badges">
                        <span class="dc-upcoming-events__badge dc-upcoming-events__badge--mode">@ev.AttendanceMode</span>
                    </div>
                </li>
            }
        </ul>
    }
</section>

@functions {
    static string FormatOffset(TimeSpan offset)
    {
        if (offset == TimeSpan.Zero) return "UTC";
        var sign = offset < TimeSpan.Zero ? "-" : "+";
        var abs = offset.Duration();
        return abs.Minutes == 0
            ? $"UTC{sign}{abs.Hours}"
            : $"UTC{sign}{abs.Hours}:{abs.Minutes:D2}";
    }
}
