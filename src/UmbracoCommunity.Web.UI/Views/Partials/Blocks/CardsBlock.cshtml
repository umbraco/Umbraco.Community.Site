@using Umbraco.Cms.Core.Models.Blocks
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<Umbraco.Cms.Core.Models.Blocks.BlockGridItem<CardsBlock, SettingsCardsBlock>>

@functions {
    bool IsImageOnlyCard(BlockGridItem item)
    {
        if (item.Content is not CardWithImageAndTextBlock card) return false;
        var cardContent = card.CardContent;
        if (cardContent == null || !cardContent.Any()) return false;
        return cardContent.All(c =>
            c.Content.ContentType.Alias == ImageBlock.ModelTypeAlias ||
            c.Content.ContentType.Alias == ImageBlockWithOverlay.ModelTypeAlias);
    }

    bool IsTextOnlyCard(BlockGridItem item)
    {
        if (item.Content is not CardWithImageAndTextBlock card) return false;
        var cardContent = card.CardContent;
        if (cardContent == null || !cardContent.Any()) return false;
        return cardContent.All(c => c.Content.ContentType.Alias == TextBlock.ModelTypeAlias);
    }

    bool IsImageTextPair(List<BlockGridItem> cardGroup)
    {
        if (cardGroup.Count != 2) return false;
        return (IsImageOnlyCard(cardGroup[0]) && IsTextOnlyCard(cardGroup[1])) ||
               (IsTextOnlyCard(cardGroup[0]) && IsImageOnlyCard(cardGroup[1]));
    }
}

@{
    bool hasBg = Model.Settings.HasBg();
    bool bgIsDark = hasBg && Model.Settings.IsDark();
}

@if (Model.Content.Cards != null && Model.Content.Cards.Any())
{
    var rows = Model.Content.Cards.GetRows();

    if (hasBg)
    {
        <style asp-add-nonce="true">
            #@Model.Content.IdHash {
                --block-background-color: @Model.Settings?.BackgroundColour?.Color;
            }
        </style>
    }

    <div class="dc-boxes align-center @(hasBg ? "has-bg" : string.Empty) @(bgIsDark ? "bg-dark" : string.Empty)"
         id="@Model.Content.IdHash">
        @if (!string.IsNullOrEmpty(Model.Content.Title))
        {
            <h2 class="block-title">@Model.Content.Title</h2>
        }
        @if (!Model.Content.Subtitle.IsEmptyHtmlString())
        {
            <div class="block-subtitle">
                @Html.Raw(Model.Content.Subtitle?.ToHtmlString())
            </div>
        }

        <div class="dc-boxes-row" id="@(Model.Settings?.BlockId != null ? Model.Settings?.BlockId : string.Empty)">

            @foreach (var cardGroup in rows)
                if (cardGroup != null) {
                {
                    var isImageTextPair = IsImageTextPair(cardGroup);
                    var itemsClass = "dc-boxes-row__items" + (isImageTextPair ? " dc-boxes-row__items--image-text-pair" : string.Empty);
                    <div class="@itemsClass">
                        @foreach (var item in cardGroup)
                        {
                            <partial name="@($"~/Views/Partials/Blocks/{item.Content.ContentType.Alias}.cshtml")" model="item" />
                        }
                    </div>
                }
            }
        </div>
    </div>
}