@using UmbracoCommunity.Web.Models.ViewModels.Blocks
@model IList<BlockGridRow>
@inject ILogger<UmbracoViewPage> _logger

@if (Model != null && Model.Any())
{
    <div class="dc-block-list">
        @foreach (var row in Model)
        {
            try
            {
                if (row.HasMultipleBlocks)
                {
                    <partial name="@($"~/Views/Partials/BlockRows/{row.Alias}.cshtml")" model="row" />
                }
                else
                {
                    var block = row.Blocks.FirstOrDefault();
                    if (block != null)
                    {
                        if (block.Content is FormBlock form)
                        {
                            var formBlockViewModel = new FormBlockViewModel(form);
                            <partial name="@($"~/Views/Partials/Blocks/FormBlock.cshtml")" model="formBlockViewModel" />
                        }
                        else
                        {
                            <partial name="@($"~/Views/Partials/Blocks/{block.Content.ContentType.Alias}.cshtml")" model="block" />
                        }
                    }
                }
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error rendering block row with alias {Alias}", row.Alias);
            }
        }
    </div>
}