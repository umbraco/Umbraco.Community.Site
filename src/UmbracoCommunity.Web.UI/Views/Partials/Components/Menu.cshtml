@using UmbracoCommunity.Web.Models.ViewModels.Components
@using UmbracoCommunity.Web.Models.ViewModels.Components.Navigation
@model MenuViewModel

<div class="nav-header__pointer"></div>
<dc-header class="nav-header">
    <header class="header">
        <div class="nav">
            <div class="nav-mobile-bg">
                @{
                    await RenderCtaButtons(true);
                }
            </div>
            <div class="nav-start">
                <partial name="~/Views/Partials/Components/Logo.cshtml" />
            </div>
            <nav class="nav-list">
                <ul class="nav-list__list">
                    @foreach (var item in Model.TopLevelNavigationItems)
                    {
                        RenderNavigationElement(item);
                    }
                </ul>
            </nav>
            <div class="nav-end">
                @if (Model.HasSearchPage)
                {
                    <div class="nav-end__item search-btn">
                        <button type="button" class="icon-btn" aria-label="Search">
                            @{
                                RenderSearchIcon();
                            }
                        </button>
                        <form method="GET" action="@Model.SearchPageUrl">
                            <input type="text" name="q" placeholder="What are you looking for?" autofocus />
                            <button type="button" class="icon-btn" aria-label="Search">
                                @{
                                    RenderSearchCloseIcon();
                                }
                            </button>
                        </form>
                    </div>
                }
                @{
                    await RenderCtaButtons();
                }
            </div>
            <div class="nav-mobile">
                <partial name="~/Views/Partials/Components/Logo.cshtml" />
                <div class="nav-mobile__buttons">
                    @if (Model.HasSearchPage)
                    {
                        <div class="nav-end__item search-btn">
                            <button type="button" class="icon-btn" aria-label="Search">
                                @{
                                    RenderSearchIcon();
                                }
                            </button>
                            <form method="GET" action="@Model.SearchPageUrl">
                                <input type="text" name="q" placeholder="What are you looking for?" autofocus />
                                <button type="button" class="icon-btn" aria-label="Search">
                                    @{
                                        RenderSearchCloseIcon();
                                    }
                                </button>
                            </form>
                        </div>
                    }
                    <button type="button" class="nav-mobile__item menu-btn" id="menuBtn" title="Menu">
                        <div class="icon-btn">
                            @{
                                RenderHamburgerIcon();
                                RenderCloseIcon();
                            }
                        </div>
                    </button>
                </div>
            </div>
        </div>
    </header>
</dc-header>
<div class="nav-header__overlay"></div>

@functions {

    private async Task RenderCtaButtons(bool isMobileNav = false)
    {
        if (!Model.CallToActionButtons.Any())
        {
            return;
        }
    }

    private void RenderSearchIcon()
    {
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"
             class="icon-search">
            <path d="M11 19C15.4183 19 19 15.4183 19 11C19 6.58172 15.4183 3 11 3C6.58172 3 3 6.58172 3 11C3 15.4183 6.58172 19 11 19Z"
                  stroke="#283A97" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            <path d="M21 21L16.7 16.7" stroke="#283A97" stroke-width="1.5" stroke-linecap="round"
                  stroke-linejoin="round" />
        </svg>
    }

    private void RenderCloseIcon()
    {
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"
             class="icon-close">
            <path d="M18 6L6 18" stroke="#283A97" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            <path d="M6 6L18 18" stroke="#283A97" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
    }

    private void RenderSearchCloseIcon()
    {
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="search-icon">
            <path d="M12 22C17.5228 22 22 17.5228 22 12C22 6.47715 17.5228 2 12 2C6.47715 2 2 6.47715 2 12C2 17.5228 6.47715 22 12 22Z"
                  stroke="#333333" stroke-opacity="0.5" stroke-width="1.5" stroke-linecap="round"
                  stroke-linejoin="round" />
            <path fill-rule="evenodd" clip-rule="evenodd"
                  d="M15.5303 9.53033C15.8232 9.23744 15.8232 8.76256 15.5303 8.46967C15.2374 8.17678 14.7626 8.17678 14.4697 8.46967L12 10.9393L9.53033 8.46967C9.23744 8.17678 8.76256 8.17678 8.46967 8.46967C8.17678 8.76256 8.17678 9.23744 8.46967 9.53033L10.9393 12L8.46967 14.4697C8.17678 14.7626 8.17678 15.2374 8.46967 15.5303C8.76256 15.8232 9.23744 15.8232 9.53033 15.5303L12 13.0607L14.4697 15.5303C14.7626 15.8232 15.2374 15.8232 15.5303 15.5303C15.8232 15.2374 15.8232 14.7626 15.5303 14.4697L13.0607 12L15.5303 9.53033Z"
                  fill="#333333" fill-opacity="0.5" />
        </svg>
    }

    private void RenderHamburgerIcon()
    {
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"
             class="icon-menu">
            <g id="menu 1">
                <path id="Vector" d="M4 12H20" stroke="#283A97" stroke-width="1.5" stroke-linecap="round"
                      stroke-linejoin="round" />
                <path id="Vector_2" d="M4 6H20" stroke="#283A97" stroke-width="1.5" stroke-linecap="round"
                      stroke-linejoin="round" />
                <path id="Vector_3" d="M4 18H20" stroke="#283A97" stroke-width="1.5" stroke-linecap="round"
                      stroke-linejoin="round" />
            </g>
        </svg>
    }

    private void RenderNavigationElement(INavigationElement element)
    {
        switch (element)
        {
            case NavigationItem navigationItem:
                RenderNavigationItem(navigationItem);
                break;
            case NavigationMenuItem navigationSection:
                RenderNavigationSection(navigationSection);
                break;
        }
    }

    private void RenderNavigationItem(NavigationItem item)
    {
        <li class="nav-item" tabindex="0">
            <a href="@item.Url" title="@item.Text">@item.Text</a>
        </li>
    }

    private void RenderNavigationSection(NavigationMenuItem item)
    {
        <li class="nav-item nav-item__has-dropdown" tabindex="0">
            <button type="button" class="dropdown-button" aria-label="@item.LinkTitle" title="@item.LinkTitle">
                @item.LinkTitle
                <svg width="10" height="6" viewBox="0 0 10 6" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M1 1L5 5L9 1" stroke="#283A97" stroke-width="1.5" stroke-linecap="round"
                          stroke-linejoin="round" />
                </svg>
            </button>
            <div class="nav-item__dropdown">

                <ul class="nav-list__list nav-item__dropdown-list" style="@GetGridColumnsTemplate(item)">
                    @foreach (var section in item.Links)
                    {
                        var hasHeadline = !string.IsNullOrEmpty(section.Headline);
                        <li class="nav-item__dropdown-item @(!hasHeadline ? "no-headline" : "")">
                            @if (hasHeadline)
                            {
                                <span>@(section.Headline)</span>
                            }
                            @foreach (var sectionItem in section.Links)
                            {
                                var hasCaption = !string.IsNullOrEmpty(sectionItem.Caption);
                                <a href="@sectionItem.Url" title="@sectionItem.Text"
                                   class="@(hasCaption ? "has-caption" : "")">
                                    <section>
                                        @if (!string.IsNullOrEmpty(sectionItem.IconUrl))
                                        {
                                            var isSvg = sectionItem.IconUrl.GetFileExtension() == ".svg";

                                            <img class="@(isSvg ? "svg-icon" : "")" src="@sectionItem.IconUrl"
                                                 alt="@sectionItem.Text" width="24"
                                                 height="24" />
                                        }
                                        <span>
                                            @sectionItem.Text
                                            @if (hasCaption)
                                            {
                                                <small>@sectionItem.Caption</small>
                                            }
                                        </span>
                                    </section>
                                </a>
                            }
                        </li>
                    }
                </ul>
            </div>
        </li>
    }

    string GetGridColumnsTemplate(NavigationMenuItem menuItem)
    {
        var columns = Enumerable.Repeat("1fr", (int)menuItem.Links.Count());
        return $"grid-template-columns: {string.Join(' ', columns)};";
    }

}
