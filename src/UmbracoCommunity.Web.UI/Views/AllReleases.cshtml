@using UmbracoCommunity.Web.Models.Pages
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<AllReleasesPageViewModel>
@{
    Layout = "LayoutReleases.cshtml";
}

<div class="dc-block-list releases-container all-releases-page">
    <h1 class="all-releases-title">All Releases</h1>

    @if (!Model.VersionGroups.Any())
    {
        <div class="empty-state">
            <p>No release information available yet. Release discussions will be synced from GitHub automatically.</p>
        </div>
    }

    @foreach (var versionGroup in Model.VersionGroups)
    {
        <div class="version-group">
            <div class="version-group-header">
                <h2 class="version-group-title">Version @versionGroup.MajorVersion</h2>
                @if (versionGroup.LatestRelease != null && versionGroup.LatestRelease.IsLts)
                {
                    <span class="lts-badge">LTS</span>
                }
            </div>

            @if (versionGroup.LatestRelease != null)
            {
                var release = versionGroup.LatestRelease;
                <div class="latest-release-card">
                    <h3 class="release-version">
                        <a href="/release/umbraco/Umbraco-CMS/@release.Version">v@(release.DisplayVersion)</a>
                    </h3>
                    <div class="release-meta">
                        @if (release.IssueCount > 0)
                        {
                            <span class="release-stat">Issues fixed: @release.IssueCount</span>
                        }
                        @if (release.ReleaseDate.HasValue)
                        {
                            <span class="release-stat">Released: @release.ReleaseDate.Value.ToString("ddd MMM dd yyyy")</span>
                        }
                    </div>
                </div>
            }

            @if (versionGroup.OtherReleases.Any())
            {
                <div class="other-releases-grid">
                    @foreach (var release in versionGroup.OtherReleases)
                    {
                        <a href="/release/umbraco/Umbraco-CMS/@release.Version" class="release-link">
                            @release.Version
                        </a>
                    }
                </div>
            }
        </div>
    }
</div>
