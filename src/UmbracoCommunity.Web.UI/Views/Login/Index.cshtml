@{
    Layout = null;
    var returnUrl = ViewBag.ReturnUrl as string;
    var error = ViewBag.Error as string;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Sign in — Umbraco Community</title>
    <style>
        *, *::before, *::after { box-sizing: border-box; }
        body { margin: 0; font-family: system-ui, sans-serif; background: #f5f5f0; display: grid; place-items: center; min-height: 100dvh; }
        .login-card { background: #fff; border-radius: 1rem; padding: 2.5rem 2rem; max-width: 22rem; width: 100%; text-align: center; box-shadow: 0 4px 24px rgba(0,0,0,.08); }
        .login-card__title { font-size: 1.5rem; font-weight: 700; color: #283a97; margin: 0 0 .5rem; }
        .login-card__subtitle { color: #555; font-size: .9375rem; margin: 0 0 2rem; }
        .login-card__error { background: #fff0f0; border: 1px solid #fca5a5; border-radius: .5rem; padding: .75rem 1rem; font-size: .875rem; color: #b91c1c; margin-bottom: 1.5rem; }
        .btn-github { display: inline-flex; align-items: center; gap: .625rem; background: #24292f; color: #fff; border: none; border-radius: .5rem; padding: .75rem 1.25rem; font-size: .9375rem; font-weight: 600; cursor: pointer; width: 100%; justify-content: center; transition: background .15s; }
        .btn-github:hover { background: #373e47; }
        .btn-github svg { flex-shrink: 0; }
    </style>
</head>
<body>
    <div class="login-card">
        <h1 class="login-card__title">Sign in</h1>
        <p class="login-card__subtitle">Use your GitHub account to sign in to the Umbraco Community.</p>

        @if (!string.IsNullOrEmpty(error))
        {
            <p class="login-card__error" role="alert">
                @if (error == "access_denied")
                {
                    <span>Sign-in was cancelled. Please try again.</span>
                }
                else if (error == "no_verified_email")
                {
                    <span>Your GitHub account has no verified email address. Please add and verify an email in your GitHub settings.</span>
                }
                else
                {
                    <span>Something went wrong. Please try again.</span>
                }
            </p>
        }

        <form method="post" action="/login">
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnUrl" value="@returnUrl" />
            <button type="submit" class="btn-github">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
                </svg>
                Continue with GitHub
            </button>
        </form>
    </div>
</body>
</html>
