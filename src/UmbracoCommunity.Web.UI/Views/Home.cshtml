@using UmbracoCommunity.Web.Models.Pages
@using UmbracoCommunity.Web.Models.ViewModels.Blocks.Cards
@inherits UmbracoViewPage<HomePageViewModel>

@{
    Layout = "Layout.cshtml";
}

<div class="dc-block-list">
    @foreach(var row in Model.BlockContent)
    {
        if (row.HasMultipleBlocks)
        {
            <partial name="@($"~/Views/Partials/BlockRows/{row.Alias}.cshtml")" model="row" />
        } else
        {
            var block = row.Blocks.FirstOrDefault();
            if (block != null)
            {
                <partial name="@($"~/Views/Partials/Blocks/{block.Content.ContentType.Alias}.cshtml")" model="block" />
            }
        }
    }

    <a class="dc-cta-block" href="#" target="#">
        <h2>This is a small call to action</h2>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 44 44" fill="none">
            <circle cx="22" cy="22" r="21" />
            <path d="M13 21.2964H31.5849" />
            <path d="M29.9883 23.8701L24.4951 29.4882" />
            <path d="M23.7979 13.3184L31.6055 21.2963" />
        </svg>
    </a>

</div>


