@using UmbracoCommunity.Web.Models.Pages
@inherits UmbracoViewPage<HomePageViewModel>

@{
    Layout = "_Layout.cshtml";
}

<section>
    <div class="dc-block-list block-list-root">

        <div class="dc-text-block justify-center " id="MEGMU">
            <style nonce="">
                #MEGMU {
                    --block-background-color: transparent;
                    --block-text-color: #162335;
                    --link-color: var(--color-blue);
                }
            </style>
            <div class="dc-text-block__content">
                <h2 style="text-align: center;">Welcome to the Umbraco Community!</h2>
                <p style="text-align: center;">The Umbraco Community is a part of the Umbraco ecosystem, which through action, involvement and co-operation, makes Umbraco what it is today!</p>
                <p style="text-align: center;">Come and explore the ways the Community stays connected, what makes it so special, and how you can get involved.</p>
                <p style="text-align: center;">From Umbraco meetups to MVP's, Community Teams to Contribution Stories and so much more, what are you waiting for?</p>
            </div>
        </div>

        <div class="dc-columns no-outline " id="uHvEH">
            <style nonce="">
                #uHvEH {
                    --block-background-color: transparent;
                    --block-text-color: #162335;
                    --block-link-color: #162335;
                }
            </style>
            <div class="column-block">
                <div class="dc-block-list">

                    <div class="dc-image-block " id="qleMC">
                        <style nonce="">
                            #qleMC {
                                --block-background-color: transparent;
                            }
                        </style>

                        <div class="dc-image-wrapper">
                            <img src="/media/zz2bofhx/mvp-summit-audience.jpg?rmode=pad&amp;width=680&amp;v=1dad67ccb364070" alt="Img 9124 1" class="dc-image" loading="lazy">
                        </div>
                    </div>

                </div>
            </div>
            <div class="column-block">
                <div class="dc-block-list">


                    <div class="dc-text-block justify-center " id="bYggB">
                        <style nonce="">
                            #bYggB {
                                --block-background-color: transparent;
                                --block-text-color: #162335;
                                --link-color: var(--color-blue);
                            }
                        </style>
                        <div class="dc-text-block__content">
                            <h2><strong>Community Events</strong></h2>
                            <p>Being social brings, and holds, the community together.&nbsp;</p> <p>There are numerous events, meetups and festivals of all shapes and sizes, already&nbsp; happening all the time in the community, across<br>the globe. If you'd like to attend, see what's coming up in your timezone on <a rel="noopener" href="https://umbracalendar.com" target="_blank">umbracalendar.com</a>!</p> <p>
                                If you're interested in setting up a local meetup or have an event idea, please <a rel="noopener" href="#" target="_blank" title="Starting your own Umbraco Meetups">read how&nbsp; we can help you</a>.
                            </p>
                        </div>
                    </div>

                </div>
            </div>
        </div>

        <div class="dc-columns no-outline " id="ZdMNG">
            <style nonce="">
                #ZdMNG {
                    --block-background-color: transparent;
                    --block-text-color: #162335;
                    --block-link-color: #162335;
                }
            </style>
            <div class="column-block">
                <div class="dc-block-list">


                    <div class="dc-text-block justify-center " id="YwYho">
                        <style nonce="">
                            #YwYho {
                                --block-background-color: transparent;
                                --block-text-color: #162335;
                                --link-color: var(--color-blue);
                            }
                        </style>
                        <div class="dc-text-block__content">
                            <h2><strong>The Community Teams</strong></h2>
                            <p>HQ'ers and members of the community work hand-in-hand in the spirit of Openness.</p>
                            <p>From Packages to Documentation, Accessibility to Diversity and Inclusion, our Community Teams endeavour to improve Umbraco and all it has to offer, for the benefit of developers and users alike.</p>
                            <p>Would you like to get involved in a community team? Find out how, <a rel="noopener" href="/learn-about-the-community/community-teams/" target="_blank" title="Community Teams">here</a>.</p>
                        </div>
                    </div>

                </div>
            </div>
            <div class="column-block">
                <div class="dc-block-list">

                    <div class="dc-image-block " id="atmMI">
                        <style nonce="">
                            #atmMI {
                                --block-background-color: transparent;
                            }
                        </style>

                        <div class="dc-image-wrapper">
                            <img src="/media/iudinajh/sus-team.jpeg?rmode=pad&amp;width=680&amp;v=1dad67d3ac201e0" alt="Niklas Hammock2" class="dc-image" loading="lazy">

                        </div>
                    </div>

                </div>
            </div>
        </div>

        <div class="dc-columns no-outline " id="nttli">
            <style nonce="">
                #nttli {
                    --block-background-color: transparent;
                    --block-text-color: #162335;
                    --block-link-color: #162335;
